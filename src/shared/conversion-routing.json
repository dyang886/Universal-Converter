{
  "packs": {
    "ffmpeg": {
      "name": "FFmpeg",
      "platform": "windows",
      "rootDir": "dependencies/ffmpeg",
      "commands": ["ffmpeg", "um"],
      "binDirs": ["dependencies/ffmpeg"],
      "requiredFiles": ["dependencies/ffmpeg/ffmpeg.exe", "dependencies/ffmpeg/um.exe"],
      "env": {}
    },
    "imagemagick": {
      "name": "ImageMagick",
      "platform": "windows",
      "rootDir": "dependencies/imagemagick",
      "commands": ["magick", "heif-enc", "JXREncApp"],
      "binDirs": ["dependencies/imagemagick", "dependencies/imagemagick/libheif", "dependencies/imagemagick/libjxr"],
      "requiredFiles": [
        "dependencies/imagemagick/magick.exe", "dependencies/imagemagick/delegates.xml",
        "dependencies/imagemagick/libheif/heif-enc.exe", "dependencies/imagemagick/libjxr/JXREncApp.exe"
      ],
      "env": {
        "MAGICK_CONFIGURE_PATH": "dependencies/imagemagick"
      }
    },
    "ghostscript": {
      "name": "Ghostscript",
      "platform": "windows",
      "rootDir": "dependencies/ghostscript",
      "commands": ["gswin64c"],
      "binDirs": ["dependencies/ghostscript/bin"],
      "requiredFiles": [
        "dependencies/ghostscript/bin/gswin64c.exe", "dependencies/ghostscript/bin/gsdll64.dll",
        "dependencies/ghostscript/lib", "dependencies/ghostscript/Resource/Init"
      ],
      "env": {
        "GS_LIB": [
          "dependencies/ghostscript/lib", "dependencies/ghostscript/Resource/Init",
          "dependencies/ghostscript/Resource", "dependencies/ghostscript/Resource/Font",
          "dependencies/ghostscript/iccprofiles"
        ]
      }
    },
    "libreoffice": {
      "name": "LibreOffice",
      "platform": "windows",
      "rootDir": "dependencies/libreoffice",
      "commands": ["soffice.com"],
      "binDirs": ["dependencies/libreoffice/program"],
      "requiredFiles": [
        "dependencies/libreoffice/program/soffice.com",
        "dependencies/libreoffice/program/fundamental.ini",
        "dependencies/libreoffice/share/registry"
      ],
      "env": {}
    },
    "pandoc": {
      "name": "Pandoc",
      "platform": "windows",
      "rootDir": "dependencies/pandoc",
      "commands": ["pandoc"],
      "binDirs": ["dependencies/pandoc"],
      "requiredFiles": ["dependencies/pandoc/pandoc.exe"],
      "env": {}
    },
    "ocr": {
      "name": "OCR",
      "platform": "windows",
      "rootDir": "dependencies/ocr",
      "commands": ["uct-ocr.exe"],
      "binDirs": ["dependencies/ocr/runtime", "dependencies/ocr/tesseract"],
      "requiredFiles": [
        "dependencies/ocr/runtime/uct-ocr.exe",
        "dependencies/ocr/tesseract/tesseract.exe",
        "dependencies/ocr/tesseract/tessdata/eng.traineddata"
      ],
      "env": {
        "UCT_OCR_HOME": "dependencies/ocr",
        "TESSDATA_PREFIX": "dependencies/ocr/tesseract/tessdata"
      }
    }
  },
  "routes": [
    {
      "kind": "ffmpeg",
      "inputGroup": ["audio"],
      "outputGroup": ["audio"],
      "packs": ["ffmpeg"]
    },
    {
      "kind": "ffmpeg",
      "inputGroup": ["video"],
      "outputGroup": ["audio", "video"],
      "packs": ["ffmpeg"]
    },
    {
      "kind": "magick",
      "inputGroup": ["image"],
      "outputGroup": ["image"],
      "packs": ["imagemagick"]
    },
    {
      "kind": "magick",
      "inputGroup": ["image"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "eps", "ps", "ai"],
      "packs": ["imagemagick"]
    },
    {
      "kind": "document-ocr",
      "control": "ocr",
      "inputGroup": ["image"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "txt"],
      "packs": ["ocr", "ghostscript"]
    },
    {
      "kind": "document-ocr",
      "control": "ocr",
      "inputGroup": ["document"],
      "inputExt": ["pdf"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "txt"],
      "packs": ["ocr", "ghostscript"]
    },
    {
      "kind": "document-postscript",
      "inputGroup": ["document"],
      "inputExt": ["pdf", "ps", "eps", "ai"],
      "outputGroup": ["image"],
      "packs": ["imagemagick", "ghostscript"]
    },
    {
      "kind": "document-postscript",
      "inputGroup": ["document"],
      "inputExt": ["pdf", "ps", "eps", "ai"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "ps", "eps", "ai"],
      "packs": ["imagemagick", "ghostscript"]
    },
    {
      "kind": "document-pandoc-to-pdf",
      "inputGroup": ["document"],
      "inputExt": [
        "md", "tex", "rst", "org", "adoc", "asciidoc", "textile", "typ",
        "ipynb", "opml", "fb2", "djot", "gfm", "commonmark", "mediawiki",
        "dokuwiki", "dbk", "man", "muse"
      ],
      "outputGroup": ["document"],
      "outputExt": ["pdf"],
      "packs": ["pandoc", "libreoffice"]
    },
    {
      "kind": "document-pandoc-to-image",
      "inputGroup": ["document"],
      "inputExt": [
        "md", "tex", "rst", "org", "adoc", "asciidoc", "textile", "typ",
        "ipynb", "opml", "fb2", "djot", "gfm", "commonmark", "mediawiki",
        "dokuwiki", "dbk", "man", "muse"
      ],
      "outputGroup": ["image"],
      "packs": ["pandoc", "libreoffice", "imagemagick", "ghostscript"]
    },
    {
      "kind": "document-pandoc",
      "inputGroup": ["document"],
      "inputExt": [
        "docx", "odt", "rtf", "txt", "md", "html", "htm", "xhtml", "epub",
        "tex", "rst", "org", "adoc", "asciidoc", "textile", "typ", "ipynb",
        "opml", "fb2", "djot", "gfm", "commonmark", "mediawiki", "dokuwiki",
        "dbk", "man", "muse"
      ],
      "outputGroup": ["document"],
      "outputExt": [
        "docx", "odt", "rtf", "txt", "html", "htm", "xhtml", "epub", "md",
        "tex", "rst", "org", "adoc", "asciidoc", "textile", "typ", "ipynb",
        "opml", "fb2", "djot", "gfm", "commonmark", "mediawiki", "dokuwiki",
        "dbk", "man", "muse"
      ],
      "packs": ["pandoc"]
    },
    {
      "kind": "document-office-to-document",
      "inputGroup": ["document"],
      "inputExt": ["doc"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "docx", "doc", "odt", "rtf", "txt", "html", "htm", "xhtml", "epub"],
      "packs": ["libreoffice"]
    },
    {
      "kind": "document-office-to-document",
      "inputGroup": ["document"],
      "inputExt": ["docx", "odt", "rtf"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "doc"],
      "packs": ["libreoffice"]
    },
    {
      "kind": "document-office-to-document",
      "inputGroup": ["document"],
      "inputExt": ["txt", "html", "htm", "xhtml", "epub"],
      "outputGroup": ["document"],
      "outputExt": ["pdf"],
      "packs": ["libreoffice"]
    },
    {
      "kind": "document-office-to-document",
      "inputGroup": ["document"],
      "inputExt": ["ppt", "pptx", "odp"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "ppt", "pptx", "odp"],
      "packs": ["libreoffice"]
    },
    {
      "kind": "document-office-to-document",
      "inputGroup": ["document"],
      "inputExt": ["xls", "xlsx", "ods", "csv"],
      "outputGroup": ["document"],
      "outputExt": ["pdf", "xlsx", "xls", "ods", "csv", "html", "htm"],
      "packs": ["libreoffice"]
    },
    {
      "kind": "document-office-to-image",
      "inputGroup": ["document"],
      "inputExt": [
        "doc", "docx", "odt", "rtf", "txt", "html", "htm", "xhtml",
        "epub", "ppt", "pptx", "odp", "xls", "xlsx", "ods", "csv"
      ],
      "outputGroup": ["image"],
      "packs": ["libreoffice", "imagemagick", "ghostscript"]
    }
  ]
}
